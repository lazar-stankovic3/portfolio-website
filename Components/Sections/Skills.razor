@inherits I18nComponentBase

<section class="section skills" id="skills">
    <div class="container">
        <div class="section-head reveal">
            <span class="kicker">✨ Skills</span>
            <h2 class="section-title">@I18n.T("skills.heading")</h2>
            <p class="section-subtitle">@I18n.T("skills.subtitle")</p>
        </div>

        <div class="skills-groups">
            <div class="skills-group reveal">
                <h3>@I18n.T("skills.group.languages")</h3>
                <div class="skills-chips">
                    <span class="chip">🔷 C#</span>
                    <span class="chip">🟨 JavaScript</span>
                    <span class="chip">🔵 TypeScript</span>
                </div>
            </div>

            <div class="skills-group reveal">
                <h3>@I18n.T("skills.group.frontend")</h3>
                <div class="skills-chips">
                    <span class="chip">⚛️ React</span>
                    <span class="chip">🅰️ Angular</span>
                    <span class="chip">🎨 HTML / CSS</span>
                </div>
            </div>

            <div class="skills-group reveal">
                <h3>@I18n.T("skills.group.backend")</h3>
                <div class="skills-chips">
                    <span class="chip">🧵 ASP.NET Core</span>
                    <span class="chip">🟩 Node.js / Express</span>
                    <span class="chip">📡 SignalR</span>
                </div>
            </div>

            <div class="skills-group reveal">
                <h3>@I18n.T("skills.group.tools")</h3>
                <div class="skills-chips">
                    <span class="chip">🐘 PostgreSQL / SQL</span>
                    <span class="chip">🐳 Docker</span>
                    <span class="chip">🌱 EF Core</span>
                    <span class="chip">🔑 JWT / OAuth</span>
                    <span class="chip">🐙 Git</span>
                </div>
            </div>
        </div>
    </div>
</section>
