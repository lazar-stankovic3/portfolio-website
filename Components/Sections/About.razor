@inherits I18nComponentBase

<section class="section section-alt about" id="about">
    <div class="container">
        <div class="about-grid">
            <div class="reveal">
                <span class="kicker">@I18n.T("about.kicker")</span>
                <h2 class="section-title">@I18n.T("about.heading")</h2>
                <p class="about-body">@I18n.T("about.body")</p>
            </div>

            <div class="about-cards">
                <div class="card-sticker about-card reveal">
                    <span class="about-card-icon">🧩</span>
                    <h3>@I18n.T("about.card1.title")</h3>
                    <p>@I18n.T("about.card1.text")</p>
                </div>
                <div class="card-sticker about-card reveal">
                    <span class="about-card-icon">⚡</span>
                    <h3>@I18n.T("about.card2.title")</h3>
                    <p>@I18n.T("about.card2.text")</p>
                </div>
                <div class="card-sticker about-card reveal">
                    <span class="about-card-icon">📚</span>
                    <h3>@I18n.T("about.card3.title")</h3>
                    <p>@I18n.T("about.card3.text")</p>
                </div>
            </div>
        </div>
    </div>
</section>
